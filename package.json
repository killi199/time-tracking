{
    "name": "time-tracking",
    "version": "1.3.2",
    "versionCode": 22,
    "main": "expo-router/entry",
    "scripts": {
        "start": "expo start",
        "android": "cross-env EXPO_PUBLIC_FOSS_BUILD=false expo run:android --variant=debug",
        "android:foss": "cross-env EXPO_PUBLIC_FOSS_BUILD=true expo run:android --variant=debug",
        "android:release": "cross-env EXPO_PUBLIC_FOSS_BUILD=false expo run:android --variant=release",
        "android:release-foss": "cross-env EXPO_PUBLIC_FOSS_BUILD=true expo run:android --variant=release",
        "ios": "expo run:ios --variant=debug",
        "ios:release": "expo run:ios --variant=release",
        "typecheck": "tsc --noEmit",
        "typecheck:foss": "tsc -p tsconfig.foss.json --noEmit",
        "lint": "eslint .",
        "format": "prettier --write .",
        "test": "vitest",
        "generate-licenses": "yarn dlx license-checker-rseidelsohn --production --json --out src/licenses.json"
    },
    "expo": {
        "autolinking": {
            "android": {
                "buildFromSource": [
                    ".*"
                ]
            }
        },
        "doctor": {
            "reactNativeDirectoryCheck": {
                "exclude": [
                    "react-native-nfc-manager"
                ]
            }
        }
    },
    "dependencies": {
        "@expo/log-box": "57.0.0",
        "@expo/ui": "~57.0.2",
        "@maplibre/maplibre-react-native": "11.3.4",
        "@react-native-community/slider": "5.2.0",
        "@react-native-vector-icons/material-design-icons": "^13.1.2",
        "@react-native/metro-config": "0.86.0",
        "expo": "57.0.1",
        "expo-constants": "~57.0.2",
        "expo-document-picker": "~57.0.0",
        "expo-file-system": "~57.0.0",
        "expo-linking": "~57.0.1",
        "expo-localization": "~57.0.0",
        "expo-location": "~57.0.1",
        "expo-notifications": "~57.0.2",
        "expo-quick-actions": "6.0.1",
        "expo-router": "~57.0.2",
        "expo-sharing": "~57.0.1",
        "expo-sqlite": "~57.0.0",
        "expo-status-bar": "~57.0.0",
        "expo-system-ui": "~57.0.0",
        "expo-task-manager": "~57.0.1",
        "i18next": "26.3.1",
        "papaparse": "5.5.4",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-i18next": "17.0.8",
        "react-native": "0.86.0",
        "react-native-gesture-handler": "~2.32.0",
        "react-native-nfc-manager": "3.17.2",
        "react-native-paper": "5.15.3",
        "react-native-reanimated": "4.5.0",
        "react-native-safe-area-context": "~5.7.0",
        "react-native-screens": "4.25.2",
        "react-native-web": "0.21.2",
        "react-native-worklets": "0.10.0"
    },
    "private": true,
    "packageManager": "yarn@4.12.0",
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@eslint/js": "9.39.2",
        "@rolldown/plugin-babel": "0.2.3",
        "@types/papaparse": "5.5.2",
        "@types/react": "~19.2.14",
        "@types/react-dom": "~19.2.0",
        "@types/react-native-web": "0.19.2",
        "@vitejs/plugin-react": "6.0.3",
        "@vitest/coverage-v8": "4.1.9",
        "@vitest/eslint-plugin": "1.6.20",
        "babel-plugin-module-resolver": "5.0.3",
        "cross-env": "10.1.0",
        "eslint": "9.39.2",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.1.1",
        "eslint-plugin-sonarjs": "4.1.0",
        "prettier": "3.9.1",
        "rolldown": "1.1.2",
        "typescript": "~6.0.3",
        "typescript-eslint": "8.62.0",
        "vite": "8.1.0",
        "vitest": "4.1.9"
    }
}
