{
    "name": "time-tracking",
    "version": "1.2.11",
    "versionCode": 18,
    "main": "index.js",
    "scripts": {
        "start": "expo start",
        "android": "cross-env EXPO_PUBLIC_FOSS_BUILD=false expo run:android --variant=debug",
        "android:release": "cross-env EXPO_PUBLIC_FOSS_BUILD=false expo run:android --variant=release",
        "android:release-foss": "expo run:android --variant=release",
        "ios": "expo run:ios --variant=debug",
        "ios:release": "expo run:ios --variant=release",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vitest",
        "generate-licenses": "yarn dlx license-checker-rseidelsohn --production --json --out src/licenses.json"
    },
    "expo": {
        "autolinking": {
            "android": {
                "buildFromSource": [
                    ".*"
                ]
            }
        },
        "doctor": {
            "reactNativeDirectoryCheck": {
                "exclude": [
                    "react-native-nfc-manager"
                ]
            }
        }
    },
    "dependencies": {
        "@maplibre/maplibre-react-native": "11.0.0-beta.30",
        "@react-native-community/slider": "5.1.2",
        "@react-navigation/bottom-tabs": "^7.15.5",
        "@react-navigation/drawer": "^7.9.4",
        "@react-navigation/native": "^7.1.33",
        "@react-navigation/native-stack": "^7.14.5",
        "expo": "~55.0.15",
        "expo-constants": "~55.0.14",
        "expo-document-picker": "~55.0.13",
        "expo-file-system": "~55.0.16",
        "expo-linking": "~55.0.13",
        "expo-localization": "~55.0.13",
        "expo-location": "~55.1.8",
        "expo-notifications": "~55.0.19",
        "expo-quick-actions": "6.0.1",
        "expo-router": "~55.0.12",
        "expo-sharing": "~55.0.18",
        "expo-sqlite": "~55.0.15",
        "expo-status-bar": "~55.0.5",
        "expo-system-ui": "~55.0.15",
        "expo-task-manager": "~55.0.14",
        "i18next": "26.0.4",
        "papaparse": "5.5.3",
        "react": "19.2.0",
        "react-i18next": "17.0.3",
        "react-native": "0.83.4",
        "react-native-gesture-handler": "~2.30.0",
        "react-native-nfc-manager": "3.17.2",
        "react-native-paper": "5.15.1",
        "react-native-paper-dates": "0.23.6",
        "react-native-reanimated": "4.2.1",
        "react-native-safe-area-context": "5.6.2",
        "react-native-screens": "~4.23.0",
        "react-native-worklets": "0.7.2"
    },
    "private": true,
    "packageManager": "yarn@4.12.0",
    "devDependencies": {
        "@babel/core": "7.29.0",
        "@eslint/js": "9.39.2",
        "@types/babel__core": "7.20.5",
        "@types/papaparse": "5.5.2",
        "@types/react": "~19.2.14",
        "@vitest/coverage-v8": "4.1.4",
        "@vitest/eslint-plugin": "1.6.15",
        "babel-plugin-module-resolver": "5.0.3",
        "cross-env": "10.1.0",
        "eslint": "9.39.2",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.0.1",
        "eslint-plugin-sonarjs": "4.0.2",
        "prettier": "3.8.3",
        "typescript": "5.9.3",
        "typescript-eslint": "8.58.2",
        "vitest": "4.1.4"
    }
}
