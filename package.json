{
    "name": "time-tracking",
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "start": "expo start",
        "android": "expo run:android --variant=debug",
        "android:release": "expo run:android --variant=release",
        "ios": "expo run:ios --variant=debug",
        "ios:release": "expo run:ios --variant=release",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vitest",
        "generate-licenses": "yarn dlx license-checker-rseidelsohn --production --json --out src/licenses.json"
    },
    "expo": {
        "doctor": {
            "reactNativeDirectoryCheck": {
                "exclude": [
                    "react-native-nfc-manager"
                ]
            }
        }
    },
    "dependencies": {
        "@maplibre/maplibre-react-native": "11.0.0-beta.10",
        "@pchmn/expo-material3-theme": "1.4.0",
        "@react-native-community/slider": "5.1.2",
        "@react-navigation/bottom-tabs": "7.15.5",
        "@react-navigation/drawer": "7.9.4",
        "@react-navigation/native": "7.1.33",
        "@react-navigation/native-stack": "7.14.4",
        "expo": "^55.0.5",
        "expo-document-picker": "~55.0.8",
        "expo-file-system": "~55.0.10",
        "expo-localization": "~55.0.8",
        "expo-location": "~55.1.2",
        "expo-notifications": "~55.0.11",
        "expo-quick-actions": "6.0.1",
        "expo-sharing": "~55.0.11",
        "expo-sqlite": "~55.0.10",
        "expo-status-bar": "~55.0.4",
        "expo-system-ui": "~55.0.9",
        "expo-task-manager": "~55.0.9",
        "i18next": "25.8.14",
        "papaparse": "5.5.3",
        "react": "19.2.0",
        "react-i18next": "16.5.4",
        "react-native": "0.83.2",
        "react-native-gesture-handler": "~2.30.0",
        "react-native-nfc-manager": "3.17.2",
        "react-native-paper": "5.15.0",
        "react-native-paper-dates": "0.23.4",
        "react-native-reanimated": "4.2.1",
        "react-native-safe-area-context": "5.6.2",
        "react-native-screens": "~4.23.0",
        "react-native-worklets": "0.7.2"
    },
    "private": true,
    "packageManager": "yarn@4.12.0",
    "devDependencies": {
        "@babel/core": "7.29.0",
        "@eslint/js": "10.0.1",
        "@types/babel__core": "7.20.5",
        "@types/papaparse": "5.5.2",
        "@types/react": "~19.2.14",
        "@vitest/eslint-plugin": "1.6.9",
        "eslint": "9.39.2",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.0.1",
        "eslint-plugin-sonarjs": "4.0.1",
        "prettier": "3.8.1",
        "typescript": "5.9.3",
        "typescript-eslint": "8.55.0",
        "vitest": "4.0.18"
    }
}
