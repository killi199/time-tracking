{
    "name": "time-tracking",
    "version": "1.3.2",
    "versionCode": 22,
    "main": "index.js",
    "scripts": {
        "start": "expo start",
        "android": "cross-env EXPO_PUBLIC_FOSS_BUILD=false expo run:android --variant=debug",
        "android:foss": "cross-env EXPO_PUBLIC_FOSS_BUILD=true expo run:android --variant=debug",
        "android:release": "cross-env EXPO_PUBLIC_FOSS_BUILD=false expo run:android --variant=release",
        "android:release-foss": "cross-env EXPO_PUBLIC_FOSS_BUILD=true expo run:android --variant=release",
        "ios": "expo run:ios --variant=debug",
        "ios:release": "expo run:ios --variant=release",
        "typecheck": "tsc --noEmit",
        "typecheck:foss": "tsc -p tsconfig.foss.json --noEmit",
        "lint": "eslint .",
        "test": "vitest",
        "generate-licenses": "yarn dlx license-checker-rseidelsohn --production --json --out src/licenses.json"
    },
    "expo": {
        "autolinking": {
            "android": {
                "buildFromSource": [
                    ".*"
                ]
            }
        },
        "doctor": {
            "reactNativeDirectoryCheck": {
                "exclude": [
                    "react-native-nfc-manager"
                ]
            }
        }
    },
    "dependencies": {
        "@expo/log-box": "^56.0.13",
        "@expo/ui": "~56.0.18",
        "@maplibre/maplibre-react-native": "11.3.4",
        "@react-native-community/slider": "5.2.0",
        "@react-native-vector-icons/material-design-icons": "^13.1.2",
        "@react-native/metro-config": "0.86.0",
        "expo": "56.0.12",
        "expo-constants": "~56.0.18",
        "expo-document-picker": "~56.0.4",
        "expo-file-system": "~56.0.8",
        "expo-linking": "~56.0.14",
        "expo-localization": "~56.0.6",
        "expo-location": "~56.0.18",
        "expo-notifications": "~56.0.18",
        "expo-quick-actions": "6.0.1",
        "expo-router": "~56.2.11",
        "expo-sharing": "~56.0.18",
        "expo-sqlite": "~56.0.5",
        "expo-status-bar": "~56.0.4",
        "expo-system-ui": "~56.0.5",
        "expo-task-manager": "~56.0.19",
        "i18next": "26.3.1",
        "papaparse": "5.5.4",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-i18next": "17.0.8",
        "react-native": "0.85.3",
        "react-native-gesture-handler": "~2.31.1",
        "react-native-nfc-manager": "3.17.2",
        "react-native-paper": "5.15.3",
        "react-native-reanimated": "4.3.1",
        "react-native-safe-area-context": "~5.7.0",
        "react-native-screens": "4.25.2",
        "react-native-web": "0.21.2",
        "react-native-worklets": "0.8.3"
    },
    "private": true,
    "packageManager": "yarn@4.12.0",
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@eslint/js": "9.39.2",
        "@types/babel__core": "^7",
        "@types/papaparse": "5.5.2",
        "@types/react": "~19.2.14",
        "@types/react-dom": "~19.2.0",
        "@types/react-native-web": "0.19.2",
        "@vitejs/plugin-react": "^5",
        "@vitest/coverage-v8": "4.1.9",
        "@vitest/eslint-plugin": "1.6.20",
        "babel-plugin-module-resolver": "5.0.3",
        "cross-env": "10.1.0",
        "eslint": "9.39.2",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.1.1",
        "eslint-plugin-sonarjs": "4.1.0",
        "prettier": "3.8.4",
        "typescript": "~6.0.3",
        "typescript-eslint": "8.61.1",
        "vite": "8.0.16",
        "vitest": "4.1.9"
    }
}
