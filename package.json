{
    "name": "time-tracking",
    "version": "1.4.0",
    "versionCode": 23,
    "main": "expo-router/entry",
    "scripts": {
        "start": "expo start",
        "android": "cross-env EXPO_PUBLIC_FOSS_BUILD=false expo run:android --variant=debug",
        "android:foss": "cross-env EXPO_PUBLIC_FOSS_BUILD=true expo run:android --variant=debug",
        "android:release": "cross-env EXPO_PUBLIC_FOSS_BUILD=false expo run:android --variant=release",
        "android:release-foss": "cross-env EXPO_PUBLIC_FOSS_BUILD=true expo run:android --variant=release",
        "ios": "expo run:ios --variant=debug",
        "ios:release": "expo run:ios --variant=release",
        "typecheck": "tsc --noEmit",
        "typecheck:foss": "tsc -p tsconfig.foss.json --noEmit",
        "lint": "eslint .",
        "format": "prettier --write .",
        "test": "jest",
        "generate-licenses": "yarn dlx license-checker-rseidelsohn --production --json --out src/licenses.json"
    },
    "expo": {
        "autolinking": {
            "android": {
                "buildFromSource": [
                    ".*"
                ]
            }
        },
        "doctor": {
            "reactNativeDirectoryCheck": {
                "exclude": [
                    "react-native-nfc-manager"
                ]
            }
        }
    },
    "dependencies": {
        "@expo/ui": "~57.0.7",
        "@maplibre/maplibre-react-native": "11.3.6",
        "@react-native-community/slider": "5.2.0",
        "@react-native-vector-icons/material-design-icons": "^13.1.2",
        "@react-native/metro-config": "0.86.0",
        "expo": "~57.0.8",
        "expo-constants": "~57.0.7",
        "expo-document-picker": "~57.0.1",
        "expo-file-system": "~57.0.1",
        "expo-linking": "~57.0.4",
        "expo-localization": "~57.0.1",
        "expo-location": "~57.0.6",
        "expo-notifications": "~57.0.7",
        "expo-quick-actions": "6.0.1",
        "expo-router": "~57.0.8",
        "expo-sharing": "~57.0.7",
        "expo-sqlite": "~57.0.1",
        "expo-status-bar": "~57.0.1",
        "expo-system-ui": "~57.0.1",
        "expo-task-manager": "~57.0.6",
        "i18next": "26.3.6",
        "papaparse": "5.5.4",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-i18next": "17.0.10",
        "react-native": "0.86.0",
        "react-native-gesture-handler": "~2.32.0",
        "react-native-nfc-manager": "3.17.2",
        "react-native-paper": "5.15.3",
        "react-native-reanimated": "4.5.0",
        "react-native-safe-area-context": "~5.7.0",
        "react-native-screens": "~4.26.0",
        "react-native-web": "0.21.2",
        "react-native-worklets": "0.10.0"
    },
    "jest": {
        "preset": "jest-expo",
        "roots": [
            "<rootDir>/src"
        ],
        "setupFilesAfterEnv": [
            "<rootDir>/src/test/jestSetup.ts"
        ],
        "collectCoverageFrom": [
            "src/**/*.{ts,tsx}",
            "!src/**/*.test.{ts,tsx}",
            "!src/**/*.d.ts",
            "!src/i18n/locales/*.ts",
            "!src/test/**"
        ]
    },
    "jest-junit": {
        "outputName": "test-report.junit.xml"
    },
    "private": true,
    "packageManager": "yarn@4.12.0",
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@eslint/js": "9.39.2",
        "@jest/globals": "^29.7.0",
        "@react-native/jest-preset": "0.86.0",
        "@types/papaparse": "5.5.2",
        "@types/react": "~19.2.14",
        "@types/react-dom": "~19.2.0",
        "@types/react-native-web": "0.19.2",
        "cross-env": "10.1.0",
        "eslint": "9.39.2",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-jest": "29.15.4",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.1.1",
        "eslint-plugin-sonarjs": "4.2.0",
        "jest": "~29.7.0",
        "jest-expo": "~57.0.2",
        "jest-junit": "17.0.0",
        "prettier": "3.9.5",
        "typescript": "~6.0.3",
        "typescript-eslint": "8.65.0"
    }
}
